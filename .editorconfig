###############################################################################
# TradePilot OS
# Enterprise EditorConfig
###############################################################################

# Top-most EditorConfig file
root = true

###############################################################################
# Global Settings
###############################################################################

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

###############################################################################
# Markdown Files
###############################################################################

[*.md]
trim_trailing_whitespace = false
max_line_length = off

###############################################################################
# YAML Files
###############################################################################

[*.{yml,yaml}]
indent_size = 2

###############################################################################
# JSON Files
###############################################################################

[*.json]
indent_size = 2

###############################################################################
# TOML Files
###############################################################################

[*.toml]
indent_size = 4

###############################################################################
# Python Files
###############################################################################

[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

###############################################################################
# Batch Files
###############################################################################

[*.{bat,cmd}]
end_of_line = crlf

###############################################################################
# PowerShell
###############################################################################

[*.ps1]
end_of_line = crlf

###############################################################################
# Shell Scripts
###############################################################################

[*.sh]
end_of_line = lf

###############################################################################
# GitHub Actions
###############################################################################

[*.{yml,yaml}]
indent_size = 2