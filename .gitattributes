###############################################################################
# TradePilot OS
# Enterprise Git Attributes
###############################################################################

###############################################################################
# Default
###############################################################################

* text=auto eol=lf

###############################################################################
# Python
###############################################################################

*.py text eol=lf

###############################################################################
# Configuration Files
###############################################################################

*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

###############################################################################
# Documentation
###############################################################################

*.md text eol=lf
*.txt text eol=lf

###############################################################################
# Shell Scripts
###############################################################################

*.sh text eol=lf

###############################################################################
# Windows Scripts
###############################################################################

*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

###############################################################################
# XML
###############################################################################

*.xml text eol=lf

###############################################################################
# CSV
###############################################################################

*.csv text eol=lf

###############################################################################
# Binary Files
###############################################################################

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary

*.pdf binary

*.zip binary
*.7z binary
*.rar binary

*.exe binary
*.dll binary

###############################################################################
# Office Files
###############################################################################

*.xlsx binary
*.xls binary
*.docx binary
*.pptx binary

###############################################################################
# Database Files
###############################################################################

*.db binary
*.sqlite binary
*.sqlite3 binary

###############################################################################
# Fonts
###############################################################################

*.ttf binary
*.otf binary

###############################################################################
# Media
###############################################################################

*.mp4 binary
*.avi binary
*.mov binary
*.mp3 binary
*.wav binary
